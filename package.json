{
  "name": "fitpro",
  "version": "1.0.0",
  "description": "FitPro 개인 피트니스 관리 웹앱",
  "scripts": {
    "dev":     "npx serve . -p 3000 --no-clipboard",
    "start":   "npx serve . -p 3000 --no-clipboard",
    "deploy":  "npx wrangler pages deploy . --project-name fitpro",
    "docker":  "docker-compose up -d",
    "docker:build": "docker-compose up -d --build",
    "docker:stop":  "docker-compose down",
    "docker:logs":  "docker-compose logs -f"
  },
  "keywords": ["fitness", "health"],
  "author": "Jason"
}

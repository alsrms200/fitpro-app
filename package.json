{
  "name": "fitpro",
  "version": "1.0.0",
  "description": "FitPro 개인 피트니스 관리 웹앱",
  "scripts": {
    "dev": "npx serve . -p 3000 --no-clipboard",
    "start": "npx serve . -p 3000 --no-clipboard",
    "deploy": "npx wrangler pages deploy . --project-name fitpro",
    "docker": "docker-compose up -d",
    "docker:up": "docker-compose up -d",
    "docker:build": "docker-compose up -d --build",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "fitness",
    "health"
  ],
  "author": "Jason",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0"
  }
}
